  },
  "GRAVITY_2": {
    "middle": {
      "_text": "カードを2枚引く。このラインから、またはこのラインへとカードを1枚移動させる。",
      "ops": [
        { "op": "draw", "count": 2 },
        { "op": "shift", "dest": "fromOrToThisLine" }
      ]
    }
  },
  "GRAVITY_3": {
    "middle": {
      "_text": "カードを1枚反転させる。そのカードをこのラインへと移動させる。",
      "ops": [
        { "op": "flip", "bind": "t" },
        { "op": "shift", "select": { "ref": "t" }, "dest": "thisLine" }
