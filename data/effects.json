{
  "_meta": {
    "dslVersion": 1,
    "spec": "docs/effects-dsl.md",
    "source": "data/cards.json (公式エラッタ適用済み・番号は公式0-5を1-6に+1シフト)",
    "notes": [
      "_text は cards.json の原文コピー(検証スクリプトで照合)。",
      "select のデフォルト: owner=any, facing=any, coverage=uncovered, zone=anywhere, count=1, mode=pick。",
      "actor 省略時の行為者はカードの owner。player/actor=opp は相手が自分で選択・実行する。"
    ]
  },

  "DARKNESS_1": {
    "middle": {
      "_text": "カードを3枚引く。相手の覆われているカードを1枚移動させる。",
      "ops": [
        { "op": "draw", "count": 3 },
        { "op": "shift", "select": { "owner": "opp", "coverage": "covered" } }
      ]
    }
  },
  "DARKNESS_2": {
    "middle": {
      "_text": "相手のカードを1枚反転させる。あなたはそのカードを移動させることができる。",
      "ops": [
        { "op": "flip", "select": { "owner": "opp" }, "bind": "t" },
        { "op": "shift", "select": { "ref": "t" }, "optional": true }
      ]
    }
  },
  "DARKNESS_3": {
    "upper": {
      "_text": "このスタックにあるすべての裏向きのカードの値はそれぞれ4になる。",
      "static": { "kind": "setValue", "value": 4, "filter": { "zone": "thisStack", "facing": "down" } }
    },
    "middle": {
      "_text": "このラインにある、覆われているカードを1枚反転させることができる。",
      "ops": [
        { "op": "flip", "select": { "zone": "thisLine", "coverage": "covered" }, "optional": true }
      ]
    }
  },
  "DARKNESS_4": {
    "middle": {
      "_text": "他の1ラインにカードを裏向きで1枚プレイする。",
      "ops": [
        { "op": "play", "source": "hand", "facing": "down", "dest": "otherLine" }
      ]
    }
  },
  "DARKNESS_5": {
    "middle": {
      "_text": "裏向きのカードを1枚移動させる。",
      "ops": [
        { "op": "shift", "select": { "facing": "down" } }
      ]
    }
  },
  "DARKNESS_6": {
    "middle": {
      "_text": "あなたは手札を1枚捨て札にする。",
      "ops": [
        { "op": "discard", "count": 1 }
      ]
    }
  },

  "DEATH_1": {
    "middle": {
      "_text": "他の各ラインにあるカードを1枚ずつ削除する。",
      "ops": [
        { "op": "forEachLine", "lines": "otherLines", "ops": [
          { "op": "delete", "select": { "zone": "currentLine" } }
        ] }
      ]
    }
  },
  "DEATH_2": {
    "upper": {
      "_text": "開始：カードを1枚引くことができる。そうした場合、他のカードを1枚削除し、そのあとこのカードを削除する。",
      "trigger": { "on": "start", "ops": [
        { "op": "draw", "count": 1, "optional": true },
        { "op": "ifDone", "ops": [
          { "op": "delete", "select": { "exclude": "thisCard" } },
          { "op": "delete", "select": { "ref": "this" } }
        ] }
      ] }
    }
  },
  "DEATH_3": {
    "middle": {
      "_text": "1ラインを選び、そのラインの値が1か2どちらかのすべてのカードを削除する。",
      "ops": [
        { "op": "delete", "select": { "zone": "chosenLine", "value": { "in": [1, 2] }, "mode": "all" } }
      ]
    }
  },
  "DEATH_4": {
    "middle": {
      "_text": "裏向きのカードを1枚削除する。",
      "ops": [
        { "op": "delete", "select": { "facing": "down" } }
      ]
    }
  },
  "DEATH_5": {
    "middle": {
      "_text": "値が0か1のカードを1枚削除する。",
      "ops": [
        { "op": "delete", "select": { "value": { "in": [0, 1] } } }
      ]
    }
  },
  "DEATH_6": {
    "middle": {
      "_text": "あなたは手札を1枚捨て札にする。",
      "ops": [
        { "op": "discard", "count": 1 }
      ]
    }
  },

  "FIRE_1": {
    "middle": {
      "_text": "他のカードを1枚反転させる。カードを2枚引く。",
      "ops": [
        { "op": "flip", "select": { "exclude": "thisCard" } },
        { "op": "draw", "count": 2 }
      ]
    },
    "lower": {
      "_text": "このカードが覆われることになったとき：先にカードを1枚引き、他のカードを1枚反転させる。",
      "trigger": { "on": "wouldBeCovered", "ops": [
        { "op": "draw", "count": 1 },
        { "op": "flip", "select": { "exclude": "thisCard" } }
      ] }
    }
  },
  "FIRE_2": {
    "middle": {
      "_text": "あなたは手札を1枚捨て札にする。そうした場合、カードを1枚削除する。",
      "ops": [
        { "op": "discard", "count": 1 },
        { "op": "ifDone", "ops": [ { "op": "delete" } ] }
      ]
    }
  },
  "FIRE_3": {
    "middle": {
      "_text": "あなたは手札を1枚捨て札にする。そうした場合、カードを1枚戻す。",
      "ops": [
        { "op": "discard", "count": 1 },
        { "op": "ifDone", "ops": [ { "op": "return" } ] }
      ]
    }
  },
  "FIRE_4": {
    "lower": {
      "_text": "終了：あなたは手札を1枚捨て札にすることができる。そうした場合、カードを1枚反転させる。",
      "trigger": { "on": "end", "ops": [
        { "op": "discard", "count": 1, "optional": true },
        { "op": "ifDone", "ops": [ { "op": "flip" } ] }
      ] }
    }
  },
  "FIRE_5": {
    "middle": {
      "_text": "あなたは手札があれば1枚以上捨て札にする。捨て札にした枚数＋1枚のカードを引く。",
      "ops": [
        { "op": "discard", "count": { "min": 1, "max": "any" }, "bind": "n" },
        { "op": "drawByCount", "ref": "n", "plus": 1 }
      ]
    }
  },
  "FIRE_6": {
    "middle": {
      "_text": "あなたは手札を1枚捨て札にする。",
      "ops": [
        { "op": "discard", "count": 1 }
      ]
    }
  },

  "GRAVITY_1": {
    "middle": {
      "_text": "このライン内にあるカード2枚ごとに、あなたのデッキの一番上のカード1枚をこのカードの下に裏向きでプレイする。",
      "ops": [
        { "op": "repeatPer", "per": { "count": "cardsInThisLine", "divisor": 2 }, "ops": [
          { "op": "play", "source": "topDeck", "facing": "down", "dest": "underThisCard" }
        ] }
      ]
