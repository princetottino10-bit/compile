    }
  },
  "GRAVITY_4": {
    "middle": {
      "_text": "裏向きのカードを1枚、このラインへと移動させる。",
      "ops": [
        { "op": "shift", "select": { "facing": "down" }, "dest": "thisLine" }
      ]
    }
  },
  "GRAVITY_5": {
    "middle": {
      "_text": "あなたは手札を1枚捨て札にする。",
      "ops": [
        { "op": "discard", "count": 1 }
      ]
    }
  },
  "GRAVITY_6": {
    "middle": {
      "_text": "相手は自分のデッキの一番上のカードをこのラインに裏向きで1枚プレイする。",
      "ops": [
        { "op": "play", "player": "opp", "source": "topDeck", "facing": "down", "dest": "thisLine" }
      ]
    }
  },

  "LIFE_1": {
    "upper": {
      "_text": "終了：このカードが覆われている場合、このカードを削除する。",
      "trigger": { "on": "end", "ops": [
